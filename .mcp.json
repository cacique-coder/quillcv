{
  "mcpServers": {
    "ga4": {
      "command": "uvx",
      "args": ["analytics-mcp"],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${HOME}/.config/quillcv/g4-sa.json",
        "GOOGLE_PROJECT_ID": "quillcv"
      }
    },
    "gsc": {
      "command": "npx",
      "args": ["-y", "mcp-server-gsc"],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${HOME}/.config/quillcv/g4-sa.json"
      }
    }
  }
}
