# QuillCV Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── Session & JWT ──────────────────────────────────────────────
# Change these in production — any random 32+ char string works.
SESSION_SECRET=quillcv-dev-secret-change-in-prod
JWT_SECRET=quillcv-jwt-dev-secret-change-in-prod

# Path to the SQLite session store. Defaults to
# $XDG_STATE_HOME/quillcv/sessions.db (i.e. ~/.local/state/quillcv/sessions.db
# on Linux) so the file lives outside the project bind-mount and host vs.
# container processes can't fight over its ownership. compose.yml overrides
# this to /var/lib/quillcv/sessions.db inside the container.
# SESSION_DB_PATH=

# ── Database ───────────────────────────────────────────────────
# The Postgres URL is assembled from the parts below (see config/settings.py).
# Only DB_HOST normally differs between environments:
#   - host-mode dev (`mise run dev`):  DB_HOST=localhost  (default)
#   - inside docker compose:           DB_HOST=db         (set by compose.yml)
#   - production / managed Postgres:   set DATABASE_URL instead — it overrides
#                                      everything below.
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=quillcv_dev      # quillcv_test in APP_ENV=test
# DB_DRIVER=postgresql+asyncpg
# DATABASE_URL=            # full URL override; wins over the parts above

# ── LLM Provider ───────────────────────────────────────────────
# Options:
#   anthropic   – Claude API (heavy: claude-sonnet-4, light: claude-haiku-4-5)
#   openai      – OpenAI API (heavy: gpt-5, light: gpt-4o-mini)
#   gemini      – Google Gemini API (heavy: gemini-2.5-pro, light: gemini-2.5-flash-lite)
#   claude-code – Local `claude` CLI; routes through your Claude subscription
#                 (no API credit). Requires the `claude` binary on PATH. Best
#                 for dev to avoid burning API budget while iterating.
#
# When LLM_PROVIDER is unset and no *_API_KEY is in the environment, the app
# auto-falls-back to claude-code. The startup log prints which provider/model
# the app is actually using, e.g.:
#   LLM[heavy]: provider=claude-code model=sonnet
LLM_PROVIDER=claude-code

# Public-signup feature flag. When false, the /signup form records an
# Expression of Interest instead of creating an account, and OAuth
# callbacks reject new users (existing users can still sign in).
# Invited signups (via /signup?invite=CODE) always work regardless.
#
# Default: true in development/test, false in production.
# OPEN_SIGNUPS_ENABLED=false

# Only set the API key for the provider you've chosen above.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# When running in docker-compose with LLM_PROVIDER=claude-code, the app
# shells out to `claude` inside the container. compose.yml bind-mounts the
# host's binary + config in by default; override these if your install
# isn't the standard Linux native installer (~/.local/bin/claude →
# self-contained ELF, ~/.claude/ for auth).
# CLAUDE_HOST_BIN=${HOME}/.local/bin/claude
# CLAUDE_HOST_CONFIG=${HOME}/.claude
# Timeout in seconds for the local `claude` CLI subprocess used by the
# claude-code LLM provider. The CLI is markedly slower than the API; the
# default is 600 (10 min) since this provider is dev-only.
# CLAUDE_CODE_TIMEOUT=600

# ── Mailgun (email sending) ─────────────────────────────────────
# US region endpoint: api.mailgun.net
# Get these from https://app.mailgun.com/mg/sending/domains
#
# When SESSION_SECRET is the default dev value (above), emails are logged
# instead of sent — no Mailgun credentials needed for local development.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── Stripe (payments) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ── Cloudflare R2 (photo storage) ──────────────────────────────
# Optional — photos are stored locally if R2 is not configured.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── OAuth (optional) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Encryption ─────────────────────────────────────────────────
# Fernet key for PII vault server-side encryption (OAuth users).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
